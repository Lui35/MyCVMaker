{
  "name": "cv-maker",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build",
    "lint:web": "npm --prefix apps/web run lint",
    "dev:api": "python -m uvicorn app.main:app --reload --app-dir apps/api",
    "setup:api": "python -m pip install -r apps/api/requirements.txt"
  }
}
